FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    UV_NO_CACHE=1

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh

ENV PATH="/root/.local/bin:${PATH}"

RUN uv pip install --system setuptools wheel
RUN uv pip install --system nemo-evaluator

COPY sber-lm-evaluation-harness /workspace/sber-lm-evaluation-harness
COPY sber-ACEBench /workspace/sber-ACEBench

RUN uv pip install --system "/workspace/sber-lm-evaluation-harness[api]"
RUN uv pip install --system openai pandas openpyxl python-dotenv tqdm wcwidth

COPY sber-ACEBench/nemo_harness/sber_acebench_bridge /workspace/core_evals/sber_acebench_bridge

ENV PYTHONPATH=/workspace

CMD ["nemo-evaluator", "run_eval"]
